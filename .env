# VM addresses
GATEWAY_VM_IP=192.168.56.12
INVENTORY_VM_IP=192.168.56.11
BILLING_VM_IP=192.168.56.13

# API ports
GATEWAY_APP_PORT=8080
INVENTORY_APP_PORT=8080

# API Gateway -> Inventory upstream
INVENTORY_API_URL=http://192.168.56.11:8080
INVENTORY_PROXY_TIMEOUT=10

# Inventory database
INVENTORY_DB_HOST=127.0.0.1
INVENTORY_DB_PORT=5432
INVENTORY_DB_NAME=movies_db
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=inventory_password

# Billing database
BILLING_DB_HOST=127.0.0.1
BILLING_DB_PORT=5432
BILLING_DB_NAME=orders_db
BILLING_DB_USER=billing_user
BILLING_DB_PASSWORD=billing_password

# RabbitMQ shared settings
RABBITMQ_HOST=192.168.56.13
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER=billing_rmq_user
RABBITMQ_PASSWORD=billing_rmq_password
BILLING_QUEUE=billing_queue